# 复制为 .env 后供 docker compose 读取
# cp .env.example .env

# 行动中止派 API 端口（勿改，与 docker-compose 映射一致）
PORT=3922

# 可选：服务端统一配置 DeepSeek（App 里也可单独填）
DEEPSEEK_API_KEY=sk-你的密钥

# 可选：ZenMux（识图 / 云端听写）
ZENMUX_API_KEY=

# 可选：阿里云百炼 DashScope（Qwen3-TTS 朗读）
DASHSCOPE_API_KEY=sk-你的百炼密钥

# PostgreSQL（docker compose 默认）
POSTGRES_PASSWORD=xzz_dev_password
DATABASE_URL=postgresql://xzz:xzz_dev_password@localhost:5433/xzz_app

# JWT（Docker / 生产必填，至少 32 字符随机串）
JWT_SECRET=请换成随机长字符串
JWT_EXPIRES_SEC=604800

# CORS（生产若提供 Web 端，逗号分隔；留空则仅允许无 Origin 的原生请求）
# CORS_ORIGINS=https://your-domain.com

# 认证：0/false 关闭公开注册；限流为单实例内存计数
# ALLOW_PUBLIC_REGISTRATION=1
# AUTH_RATE_LIMIT_MAX=30
# AUTH_REGISTER_RATE_LIMIT_MAX=5

# MAGI 集成（Phase 6，默认关闭）
MAGI_CONTENT_ENABLED=0
MAGI_CONTENT_URL=
MAGI_CONTENT_TOKEN=
MAGI_SYSTEM_ENABLED=0
MAGI_SYSTEM_URL=
MAGI_SYSTEM_TOKEN=

# Agent Runtime M1c：web_search 工具用 Tavily（https://tavily.com）
# 不填则 web_search 返回空结果（不抛错），planner 应改走 magi_system_read 或直接回复
TAVILY_API_KEY=
