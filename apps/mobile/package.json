{
  "name": "@xzz/mobile",
  "version": "0.1.0",
  "main": "index.ts",
  "scripts": {
    "start": "expo start --localhost --port 8090",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "ios:ipad": "expo run:ios --device \"iPad Pro 13-inch (M5)\"",
    "web": "expo start --web",
    "typecheck": "tsc --noEmit",
    "test": "jest",
    "test:watch": "jest --watch"
  },
  "dependencies": {
    "@react-navigation/bottom-tabs": "^7.3.13",
    "@react-navigation/native": "^7.1.9",
    "@react-navigation/native-stack": "^7.3.13",
    "@xzz/shared": "*",
    "expo": "~54.0.33",
    "expo-av": "~16.0.8",
    "expo-clipboard": "~8.0.8",
    "expo-file-system": "~19.0.22",
    "expo-image-manipulator": "~14.0.8",
    "expo-image-picker": "~17.0.10",
    "expo-media-library": "~18.2.1",
    "expo-secure-store": "~15.0.7",
    "expo-sharing": "~14.0.8",
    "expo-speech": "~14.0.7",
    "expo-speech-recognition": "^3.1.3",
    "expo-status-bar": "~3.0.9",
    "expo-text-recognition": "^0.1.1",
    "react": "19.1.0",
    "react-native": "0.81.5",
    "react-native-safe-area-context": "~5.4.0",
    "react-native-screens": "~4.11.1",
    "react-native-svg": "15.12.1",
    "react-native-view-shot": "4.0.3",
    "react-native-webview": "13.15.0"
  },
  "devDependencies": {
    "@testing-library/react-native": "^13.3.3",
    "@types/jest": "^30.0.0",
    "@types/react": "~19.1.0",
    "jest": "^29.7.0",
    "jest-expo": "~54.0.0",
    "react-test-renderer": "^19.1.0",
    "typescript": "~5.9.2"
  },
  "private": true,
  "jest": {
    "preset": "jest-expo",
    "setupFilesAfterEnv": [
      "<rootDir>/jest.setup.js"
    ],
    "moduleNameMapper": {
      "^@xzz/shared$": "<rootDir>/../../packages/shared/src/index.ts",
      "^(\\.{1,2}/.*)\\.js$": "$1"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(?:.pnpm/)?((jest-)?react-native|@react-native(-community)?|expo(nent)?|@expo(nent)?/.*|@expo-google-fonts/.*|react-navigation|@react-navigation/.*|@unimodules/.*|unimodules|sentry-expo|native-base|react-native-svg|react-native-reanimated|react-native-safe-area-context))"
    ],
    "testMatch": [
      "<rootDir>/src/**/*.test.{ts,tsx}"
    ]
  }
}
